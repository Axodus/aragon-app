# URL of the Aragon backend
ARAGON_BACKEND_URL=http://localhost/
NEXT_PUBLIC_ARAGON_BACKEND_URL=http://localhost/

# Pinata JWT token used for pinning data on IPFS (see https://knowledge.pinata.cloud/en/articles/6191471-how-to-create-an-pinata-api-key)
NEXT_SECRET_IPFS_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..8c9oCBrOjLN_CSK4rfWeU7fyTWyhYWIv00EoqV8MH8o
NEXT_SECRET_IPFS_GATEWAY=https://amethyst-blank-puma-863.mypinata.cloud
NEXT_SECRET_ARAGON_ADMIN_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJhdXRoIjoiYXJhZ29uLWFkbWluIiwiYWdlbnQiOm51bGwsInRva2VuIjoiSzRSWEdMRE9MSlJXVzUzSkpFVVU2UURQTkE0RVc1VFoiLCJpYXQiOjE3NjcwNDQ3ODR9.EX86dPMaRzyau4IUtoij74x_t12q7Mf3VXoEClJx04c

# Sentry 
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Application environment
NEXT_PUBLIC_ENV=local

# Project ID from Wallet Connect
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=5ba9c1f6c4d67b90033a3704b95ccbcd

# Allowed domain for API requests
NEXT_PUBLIC_API_ALLOWED_DOMAIN=*

# Enable/disable the debug panel
NEXT_PUBLIC_FEATURE_DEBUG=true

# Enable/disable the governance designer feature
NEXT_PUBLIC_FEATURE_GOVERNANCE_DESIGNER=true

# Enable/disable the DAO smart contract updates feature
NEXT_PUBLIC_FEATURE_OSX_UPDATES=true

# Uses the mock data defined on the backendApiMocks file when set to true
NEXT_PUBLIC_USE_MOCKS=false

# Enables all plugins for body creation flows in governance designer (avoids whitelist)
NEXT_PUBLIC_FEATURE_ENABLE_ALL_PLUGINS=true

# API version for Aragon backend service (v2 for production, v3 for dev/sandbox)
NEXT_PUBLIC_API_VERSION=v3
NEXT_PUBLIC_DEBUG_CLIENT_ERRORS=true