###############################################
# Aragon App (Next.js) — .env.example
#
# - Use this file as a reference/template.
# - Do NOT put real secrets here.
# - NEXT_PUBLIC_* variables are exposed to the client.
# - NEXT_SECRET_* and non-prefixed variables should be server-only.
###############################################

############################
# Ambiente
############################
# Environment name (used for feature gating, telemetry, and layouts)
# Common values: local | development | preview | staging | production
NEXT_PUBLIC_ENV=

############################
# Backend (DAO API)
############################
# Backend base URL. Server-side priority:
# 1) ARAGON_BACKEND_URL (server-only)
# 2) NEXT_PUBLIC_ARAGON_BACKEND_URL (fallback)
ARAGON_BACKEND_URL=
NEXT_PUBLIC_ARAGON_BACKEND_URL=

# Admin backend base URL. Server-side priority:
# 1) ARAGON_ADMIN_BACKEND_URL (server-only)
# 2) ARAGON_BACKEND_URL
# 3) NEXT_PUBLIC_ARAGON_BACKEND_URL
ARAGON_ADMIN_BACKEND_URL=

############################
# API / Segurança
############################
# Allowed domain for API requests (e.g. https://governance.country).
# For local dev you can use "*".
NEXT_PUBLIC_API_ALLOWED_DOMAIN=

# Backend API version (expected values: v2 | v3)
NEXT_PUBLIC_API_VERSION=

############################
# Flags / Features
############################
# Enables mocks from backendApiMocks.ts
NEXT_PUBLIC_USE_MOCKS=

# Enables client-side error diagnostics (useful in dev)
NEXT_PUBLIC_DEBUG_CLIENT_ERRORS=

# Enables Governance Designer
NEXT_PUBLIC_FEATURE_GOVERNANCE_DESIGNER=

# Enables OSx contract update flows
NEXT_PUBLIC_FEATURE_OSX_UPDATES=

# Enables all plugins (bypasses whitelist for some flows)
NEXT_PUBLIC_FEATURE_ENABLE_ALL_PLUGINS=

# Root mode (internal/experimental)
NEXT_PUBLIC_FEAT_ROOT=

############################
# WalletConnect
############################
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

############################
# IPFS (Pinata)
############################
# Public gateway used to render IPFS URLs on the client (e.g. https://<subdomain>.mypinata.cloud)
NEXT_PUBLIC_IPFS_GATEWAY=

# Pinata JWT for pinning (server action / server-only)
NEXT_SECRET_IPFS_JWT=

############################
# RPC Proxy (server-only)
############################
# RPC provider keys used by the server-side proxy.
# Fill at least the providers your environment requires.
NEXT_SECRET_RPC_KEY=
NEXT_SECRET_ANKR_RPC_KEY=
NEXT_SECRET_DRPC_RPC_KEY=
NEXT_SECRET_PEAQ_RPC_KEY=

############################
# Admin / Autenticação (server-only)
############################
# JWT used for admin calls (server-only)
NEXT_SECRET_ARAGON_ADMIN_JWT=

# Optional API keys (server-only) used to attach X-API-Key headers on proxy routes
NEXT_SECRET_ARAGON_BACKEND_API_KEY=
NEXT_SECRET_ARAGON_ADMIN_BACKEND_API_KEY=

############################
# Sentry / Observabilidade
############################
# DSN (can be public or server). Priority:
# 1) SENTRY_DSN
# 2) NEXT_PUBLIC_SENTRY_DSN
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry build-time (prefer non-public variables when possible)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Build-time fallbacks (avoid unless you need them)
NEXT_PUBLIC_SENTRY_ORG=
NEXT_PUBLIC_SENTRY_PROJECT=
NEXT_SECRET_SENTRY_AUTH_TOKEN=

############################
# CSP / Report-only (opcional)
############################
# Used to build report URI/key in middleware.
SENTRY_REPORT_URI=
SENTRY_REPORT_KEY=

############################
# Build / Release (opcional)
############################
# Release identifier used by monitoring (e.g. SHA, tag, version)
version=
